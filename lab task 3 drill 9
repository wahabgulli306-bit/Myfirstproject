#include <iostream>
#include <cmath>
using namespace std;

int main()
{
    // a. Define variables
    float a, b, c;
    float root1, root2, discriminant;

    // Initialize variables
    a = b = c = 0;
    root1 = root2 = discriminant = 0;

    // b. Prompt user to enter coefficients
    cout << "Enter coefficient a: ";
    cin >> a;

    cout << "Enter coefficient b: ";
    cin >> b;

    cout << "Enter coefficient c: ";
    cin >> c;

    // c. Calculate discriminant
    discriminant = (b * b) - (4 * a * c);

    if(a == 0)
    {
        cout << "Not a quadratic equation (a cannot be zero).";
    }
    else if(discriminant > 0)
    {
        root1 = (-b + sqrt(discriminant)) / (2 * a);
        root2 = (-b - sqrt(discriminant)) / (2 * a);

        cout << "\nRoots are Real and Different.";
        cout << "\nRoot 1 = " << root1;
        cout << "\nRoot 2 = " << root2;
    }
    else if(discriminant == 0)
    {
        root1 = -b / (2 * a);

        cout << "\nRoots are Real and Equal.";
        cout << "\nRoot = " << root1;
    }
    else
    {
        cout << "\nRoots are Complex (Imaginary).";
    }

    return 0;
}
