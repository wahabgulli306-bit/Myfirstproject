#include <iostream>
using namespace std;

int main()
{
    // Declare variables
    float x, y;

    // Initialize variables
    x = 0;
    y = 0;

    // Prompt user to enter value of x
    cout << "Enter the value of x: ";
    cin >> x;

    // Calculate y using equation y = 2x + 4
    y = (2 * x) + 4;

    // Display result
    cout << "For x = " << x << ", the value of y = " << y;

    return 0;
}
