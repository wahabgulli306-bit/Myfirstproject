#include <iostream>
using namespace std;

int main()
{
    // a & b. Define variables
    float R1, R2, R_net;

    // c. Initialize variables
    R1 = 0;
    R2 = 0;
    R_net = 0;

    // d. Prompt user to enter values
    cout << "Enter value of first resistor (R1): ";
    cin >> R1;

    cout << "Enter value of second resistor (R2): ";
    cin >> R2;

    // e. Calculate net resistance
    if((R1 + R2) != 0)
    {
        R_net = (R1 * R2) / (R1 + R2);

        // f. Display results
        cout << "\nResistor 1 (R1) = " << R1 << " Ohms";
        cout << "\nResistor 2 (R2) = " << R2 << " Ohms";
        cout << "\nNet Resistance (Parallel) = " << R_net << " Ohms";
    }
    else
    {
        cout << "Invalid values entered.";
    }

    return 0;
}
