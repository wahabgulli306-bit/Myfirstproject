#include <iostream>
using namespace std;

int main()
{
    // a(i). Define appropriate variables
    float subject1, subject2, subject3, subject4, subject5;
    float average;

    // a(ii). Initialize variables
    subject1 = subject2 = subject3 = subject4 = subject5 = 0;
    average = 0;

    // a. Prompt user to enter marks
    cout << "Enter marks for Subject 1: ";
    cin >> subject1;

    cout << "Enter marks for Subject 2: ";
    cin >> subject2;

    cout << "Enter marks for Subject 3: ";
    cin >> subject3;

    cout << "Enter marks for Subject 4: ";
    cin >> subject4;

    cout << "Enter marks for Subject 5: ";
    cin >> subject5;

    // b. Calculate average
    average = (subject1 + subject2 + subject3 + subject4 + subject5) / 5;

    // c. Display the average
    cout << "\nAverage Marks Obtained = " << average;

    return 0;
}
